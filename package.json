{
  "name": "contract-guard",
  "version": "1.0.0",
  "description": "Contract Guard - Security and management system for contracts",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/client\" \"npm run dev --workspace=packages/api-gateway\" \"npm run dev --workspace=packages/services\"",
    "dev:client": "npm run dev --workspace=packages/client",
    "dev:gateway": "npm run dev --workspace=packages/api-gateway",
    "dev:services": "npm run dev --workspace=packages/services",
    "build": "npm run build --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "chart.js": "^4.5.1",
    "lucide-react": "^1.7.0",
    "pdfkit": "^0.18.0",
    "react-chartjs-2": "^5.3.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  }
}
